generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  username      String   @unique
  password      String
  profilePicUrl String?
  bio           String?
  friends       String[]
  createdAt     DateTime @default(now())

  ratings ratings[]
}

model ratings {
  id        String   @id @default(uuid())
  stars     Int
  feedback  String
  createdAt DateTime @default(now())

  usersId String?
  users   users?  @relation(fields: [usersId], references: [id])
}
